{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "moduleResolution": "node",
        "sourceMap": false,
        "inlineSources": false,
        "declaration": true,
        "stripInternal": true,
        "strict": true,
        "lib": [ "ES2022" ],
        "outDir": "../out",
        "skipLibCheck": true,
        "esModuleInterop": true
    }
}