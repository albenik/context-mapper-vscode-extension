{
    "name": "context-mapper-vscode-extension-fork",
    "displayName": "Context Mapper Fork",
    "description": "The Context Mapper VS Code Extension Fork",
    "version": "1.0.0",
    "publisher": "albenik",
    "icon": "resources/contextmapper.png",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/albenik/context-mapper-vscode-extension.git"
    },
    "bugs": {
        "url": "https://github.com/albenik/context-mapper-vscode-extension/issues"
    },
    "engines": {
        "vscode": "^1.95.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "keywords": [
        "Context Mapper",
        "Context Mapping DSL",
        "CML",
        "Domain-driven Design",
        "DDD",
        "Domain-specific Language",
        "DSL",
        "Domain Modeling"
    ],
    "activationEvents": [
        "onLanguage:cml",
        "onLanguage:scl"
    ],
    "main": "out/extension",
    "contributes": {
        "languages": [
            {
                "id": "cml",
                "aliases": [
                    "Context Mapper DSL",
                    "CML",
                    "cml"
                ],
                "extensions": [
                    ".cml"
                ],
                "configuration": "./cml.configuration.json"
            },
            {
                "id": "scl",
                "aliases": [
                    "Service Cutter DSL",
                    "SCL",
                    "scl"
                ],
                "extensions": [
                    ".scl"
                ],
                "configuration": "./scl.configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "cml",
                "scopeName": "source.cml",
                "path": "./syntaxes/cml.tmLanguage.json"
            },
            {
                "language": "scl",
                "scopeName": "source.scl",
                "path": "./syntaxes/scl.tmLanguage.json"
            }
        ],
        "commands": [
            {
                "command": "cml.preview",
                "title": "Open CML Preview",
                "category": "Context Mapper",
                "icon": "$(open-preview)"
            },
            {
                "command": "cml.generate.puml.proxy",
                "title": "Generate PlantUML Diagrams",
                "when": "editorLangId == cml"
            },
            {
                "command": "cml.generate.sketchminer.proxy",
                "title": "Generate Sketch Miner Diagrams",
                "when": "editorLangId == cml"
            },
            {
                "command": "cml.generate.mdsl.proxy",
                "title": "Generate MDSL Service Contracts",
                "when": "editorLangId == cml"
            },
            {
                "command": "cml.generate.generic.text.file.proxy",
                "title": "Generate Text File with Freemarker Template",
                "when": "editorLangId == cml"
            },
            {
                "command": "cml.generate.contextmap.proxy",
                "title": "Generate Graphical Context Map",
                "when": "editorLangId == cml"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "when": "editorLangId == cml",
                    "command": "cml.preview",
                    "group": "navigation"
                }
            ],
            "editor/context": [
                {
                    "when": "resourceLangId == cml",
                    "command": "cml.preview",
                    "group": "cmlPreview@0"
                },
                {
                    "when": "resourceLangId == cml",
                    "command": "cml.generate.contextmap.proxy",
                    "group": "cmlGenerators@1"
                },
                {
                    "when": "resourceLangId == cml",
                    "command": "cml.generate.puml.proxy",
                    "group": "cmlGenerators@2"
                },
                {
                    "when": "resourceLangId == cml",
                    "command": "cml.generate.sketchminer.proxy",
                    "group": "cmlGenerators@3"
                },
                {
                    "when": "resourceLangId == cml",
                    "command": "cml.generate.generic.text.file.proxy",
                    "group": "cmlGenerators@4"
                },
                {
                    "when": "resourceLangId == cml",
                    "command": "cml.generate.mdsl.proxy",
                    "group": "cmlGenerators@5"
                }
            ]
        },
        "keybindings": [
            {
                "command": "cml.preview",
                "key": "alt+shift+p",
                "when": "editorLangId == cml"
            }
        ],
        "configuration": {
            "title": "Context Mapper",
            "properties": {
                "cml.preview.logLevel": {
                    "type": "string",
                    "enum": ["off", "info", "debug"],
                    "enumDescriptions": [
                        "Disable CML Preview logging entirely.",
                        "Log preview lifecycle events, LSP timings, artifact discovery, and errors.",
                        "Everything 'info' logs plus high-frequency events (debounce ticks, view-state changes, per-event document tracking, config values)."
                    ],
                    "default": "info",
                    "description": "Verbosity of the 'CML Preview' Output channel used to debug preview rendering.",
                    "scope": "window"
                },
                "generation.contextMapGenerator.fixImageWidth": {
                    "type": "boolean",
                    "default": false,
                    "description": "Fix the width of the generated images.",
                    "scope": "resource"
                },
                "generation.contextMapGenerator.imageWidth": {
                    "type": "integer",
                    "default": 1000,
                    "description": "Width of the generated images (in case it is fixed).",
                    "scope": "resource"
                },
                "generation.contextMapGenerator.fixImageHeight": {
                    "type": "boolean",
                    "default": false,
                    "description": "Fix the height of the generated images.",
                    "scope": "resource"
                },
                "generation.contextMapGenerator.imageHeight": {
                    "type": "integer",
                    "default": 1000,
                    "description": "Height of the generated images (in case it is fixed).",
                    "scope": "resource"
                },
                "generation.contextMapGenerator.generateLabels": {
                    "type": "boolean",
                    "default": false,
                    "description": "Generate extended labels (relationship names and implementation technologies).",
                    "scope": "resource"
                },
                "generation.contextMapGenerator.labelSpacingFactor": {
                    "type": "integer",
                    "default": 5,
                    "description": "Spacing factor: can improve results in case the images have overlapping labels.",
                    "minimum": 1,
                    "maximum": 20,
                    "scope": "resource"
                },
                "generation.contextMapGenerator.clusterTeams": {
                    "type": "boolean",
                    "default": true,
                    "description": "Cluster team Bounded Contexts and generic Bounded Contexts (relevant for team maps only).",
                    "scope": "resource"
                }
            }
        }
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.95.0",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.2.2",
        "eslint": "^10.2.0",
        "glob": "^13.0.6",
        "mocha": "^11.1.0",
        "prettier": "^3.5.3",
        "source-map-support": "^0.5.21",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.58.2"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./src",
        "lint": "eslint src",
        "format:markdown": "prettier --write \"**/*.{md,mdx}\"",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile",
        "test": "node ./out/test/runTest.js"
    }
}
